{
  "hosting": {
    "site": "awrad-motabah",
    "public": ".",
    "ignore": ["firebase.json", ".firebaserc", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          {"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"}
        ]
      }
    ]
  }
}
